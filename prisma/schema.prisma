generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BrandProject {
  id                       String               @id @default(cuid())
  name                     String
  slug                     String               @unique
  description              String?
  momentsStyleMemory       String?
  xiaohongshuStyleMemory   String?
  contentFormats           ContentFormat[]
  contentTasks             ContentTask[]
  researchCollections      ResearchCollection[]
  researchInsights         ResearchInsight[]
  researchCrawlJobs        ResearchCrawlJob[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model ContentFormat {
  id           String        @id @default(cuid())
  projectId    String
  project      BrandProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform     ContentPlatform @default(MOMENTS)
  name         String
  description  String?
  writingGuide String?
  products     Product[]
  contentTasks ContentTask[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
}

model Product {
  id              String         @id @default(cuid())
  contentFormatId String
  contentFormat   ContentFormat  @relation(fields: [contentFormatId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  sellingPoints   String[]       @default([])
  assets          ProductAsset[]
  contentTasks    ContentTask[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([contentFormatId])
}

model ProductAsset {
  id            String           @id @default(cuid())
  productId     String
  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type          ProductAssetType
  title         String?
  content       String?
  imageUrl      String?
  imageAnalysis String?
  tags          String[]         @default([])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([productId])
  @@index([type])
}

model ContentTask {
  id               String                 @id @default(cuid())
  projectId        String
  project          BrandProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform         ContentPlatform        @default(MOMENTS)
  title            String
  campaignGoal     String
  contentFormatId  String?
  contentFormat    ContentFormat?         @relation(fields: [contentFormatId], references: [id], onDelete: SetNull)
  productId        String?
  product          Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  selectedAssetIds String[]               @default([])
  status           ContentTaskStatus      @default(DRAFT)
  versions         ContentVersion[]
  calendarEntries  PublishCalendarEntry[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([contentFormatId])
  @@index([productId])
  @@index([status])
  @@index([platform])
  @@index([projectId])
}

model ContentVersion {
  id                  String      @id @default(cuid())
  taskId              String
  task                ContentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label               String
  content             String
  imageUrls           String[]    @default([])
  revisionInstruction String?
  isFinal             Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([taskId])
  @@index([isFinal])
}

model PublishCalendarEntry {
  id          String                @id @default(cuid())
  taskId      String
  task        ContentTask           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  versionId   String?
  plannedDate DateTime
  status      PublishCalendarStatus @default(PLANNED)
  note        String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([plannedDate])
  @@index([taskId])
}

model ResearchCollection {
  id          String           @id @default(cuid())
  projectId   String
  project     BrandProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    ContentPlatform  @default(XIAOHONGSHU)
  name        String
  sourceType  String
  sourceQuery String?
  description String?
  notes       ResearchNote[]
  insights    ResearchInsight[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([platform])
  @@index([projectId])
}

model ResearchNote {
  id           String             @id @default(cuid())
  collectionId String
  collection   ResearchCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  externalId   String?
  title        String?
  content      String
  authorName   String?
  authorHandle String?
  noteUrl      String?
  publishedAt  DateTime?
  keywords     String[]           @default([])
  likeCount    Int?
  commentCount Int?
  collectCount Int?
  shareCount   Int?
  viewCount    Int?
  rawPayload   Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([collectionId])
  @@index([externalId])
  @@index([publishedAt])
}

model ResearchInsight {
  id              String              @id @default(cuid())
  projectId       String
  project         BrandProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionId    String?
  collection      ResearchCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  platform        ContentPlatform     @default(XIAOHONGSHU)
  scopeKey        String?
  title           String
  summary         String
  recommendations String?
  topKeywords     String[]            @default([])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([platform])
  @@index([scopeKey])
  @@index([projectId])
}

model ResearchCrawlJob {
  id             String              @id @default(cuid())
  projectId      String
  project        BrandProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform       ContentPlatform     @default(XIAOHONGSHU)
  collectionName String
  query          String?
  creatorIds     String[]            @default([])
  crawlerType    ResearchCrawlerType @default(SEARCH)
  status         ResearchCrawlStatus @default(PENDING)
  notesImported  Int?
  sourceFilePath String?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([platform])
  @@index([status])
  @@index([createdAt])
  @@index([projectId])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductAssetType {
  TEXT  @map("text")
  IMAGE @map("image")
}

enum ContentPlatform {
  MOMENTS   @map("moments")
  XIAOHONGSHU @map("xiaohongshu")
}

enum ContentTaskStatus {
  DRAFT     @map("draft")
  FINALIZED @map("finalized")
  FAILED    @map("failed")
}

enum PublishCalendarStatus {
  PLANNED @map("planned")
  POSTED  @map("posted")
}

enum ResearchCrawlerType {
  SEARCH  @map("search")
  CREATOR @map("creator")
}

enum ResearchCrawlStatus {
  PENDING   @map("pending")
  RUNNING   @map("running")
  IMPORTING @map("importing")
  COMPLETED @map("completed")
  FAILED    @map("failed")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StyleProfile {
  id             String        @id @default(cuid())
  name           String
  description    String?
  analysisPrompt String
  sourceText     String?
  contentTasks   ContentTask[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model KnowledgeItem {
  id        String            @id @default(cuid())
  type      KnowledgeItemType
  title     String?
  content   String
  imageUrl  String?
  tags      String[]          @default([])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([type])
}

model ContentTask {
  id                   String                 @id @default(cuid())
  title                String
  campaignGoal         String
  selectedStyleId      String?
  selectedStyle        StyleProfile?          @relation(fields: [selectedStyleId], references: [id], onDelete: SetNull)
  selectedKnowledgeIds String[]               @default([])
  status               ContentTaskStatus      @default(DRAFT)
  versions             ContentVersion[]
  calendarEntries      PublishCalendarEntry[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([selectedStyleId])
  @@index([status])
}

model ContentVersion {
  id                  String      @id @default(cuid())
  taskId              String
  task                ContentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label               String
  content             String
  imageUrls           String[]    @default([])
  revisionInstruction String?
  isFinal             Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([taskId])
  @@index([isFinal])
}

model PublishCalendarEntry {
  id          String                @id @default(cuid())
  taskId      String
  task        ContentTask           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  versionId   String?
  plannedDate DateTime
  status      PublishCalendarStatus @default(PLANNED)
  note        String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([plannedDate])
  @@index([taskId])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KnowledgeItemType {
  TEXT  @map("text")
  IMAGE @map("image")
}

enum ContentTaskStatus {
  DRAFT     @map("draft")
  FINALIZED @map("finalized")
  FAILED    @map("failed")
}

enum PublishCalendarStatus {
  PLANNED @map("planned")
  POSTED  @map("posted")
}
